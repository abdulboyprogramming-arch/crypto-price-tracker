# Multi-stage build for web application
FROM node:18-alpine AS builder

WORKDIR /app

# Copy web app files (FIXED: now copies from root, not web-app/)
COPY . .

# No build step needed for static files, but prepare for future optimizations
RUN echo "Building Crypto Tracker Pro Web App"

# Production stage
FROM nginx:alpine

# Copy built files
COPY --from=builder /app /usr/share/nginx/html

# Copy custom nginx config
RUN echo 'server { \
    listen 80; \
    server_name localhost; \
    root /usr/share/nginx/html; \
    index index.html; \
    location / { \
        try_files $uri $uri/ /index.html; \
    } \
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|json)$ { \
        expires 1y; \
        add_header Cache-Control "public, immutable"; \
    } \
}' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]