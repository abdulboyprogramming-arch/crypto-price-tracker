*.log
logs/
debug.log

# Cache files
.cache/
.crypto_cache/
.crypto-config.json
.crypto-tracker-cache/

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# Test outputs
test-output/
test-results/
coverage/

