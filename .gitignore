*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# Python cache database
*.db
*.db-journal
*.sqlite
*.sqlite3

# Node.js / JavaScript
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# Browser extension build artifacts
*.crx
*.pem
*.zip

# Extension icons (generated files)
browser-extension/icons/*.png

# Web app icons (generated files)
web-app/assets/icons/*.png

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.desktop.ini
Thumbs.db

# Logs
*.log
logs/
debug.log

# Cache files
.cache/
.crypto_cache/
.crypto-config.json
.crypto-tracker-cache/

# Environment variables
.env
.env.local
.env.*.local

# OS files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?

# Test outputs
test-output/
test-results/
coverage/

# Backup files
*.bak
*.backup
*.tmp
*.temp

# Documentation build
docs/_build/
site/

# Distribution packages
dist/
build/
*.egg-info/
*.egg

# Generated version file
web-app/version.json

# Icon generation cache
scripts/__pycache__/

# Docker temporary files
.docker/

# API server runtime files
api-server/__pycache__/
api-server/*.pyc

# CLI tools generated files
cli-tools/python-cli/*.egg-info/
cli-tools/python-cli/build/
cli-tools/python-cli/dist/
cli-tools/node-cli/node_modules/

# Core engine generated files
core-engine/__pycache__/
core-engine/*.db